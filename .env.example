# Copy this file to .env.local and fill in real secrets there.
# Do not commit .env.local.

# LLM provider settings
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Pipeline reproducibility settings
LLM_PROVIDER=openai
LLM_PROMPT_VERSION=benchmark-ontology-v1
LLM_TEMPERATURE=0
LLM_MAX_OUTPUT_TOKENS=2000
LLM_REQUEST_TIMEOUT_MS=30000

# Course-note fixture settings
DEFAULT_COURSE_NOTE_PATH=docs/course-note-full.txt
COURSE_NOTE_EXCERPT_PARAGRAPH_COUNT=8
